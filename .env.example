# Path to kubeconfig (optional; defaults to ~/.kube/config).
# For multiple files use colon-separated paths (semicolon on Windows):
#   KUBECONFIG=~/.kube/config:~/other/config
# The app uses the first path to load; all contexts from that file are listed
# in the UI and you can switch context from the context selector.
# KUBECONFIG=/path/to/kubeconfig

# When running inside Kubernetes, the client uses in-cluster config automatically
# (KUBERNETES_SERVICE_HOST and KUBERNETES_SERVICE_PORT are set by the cluster).
